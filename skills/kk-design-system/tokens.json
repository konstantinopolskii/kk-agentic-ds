{
  "$schema": "https://kk.consulting/design-system/tokens.schema.json",
  "version": "0.1.0",
  "meta": {
    "source": "vars.css",
    "philosophy": "Nine color tokens, one font, seven sizes, three weights, 4px spacing grid. Additions get rejected at supervision."
  },
  "color": {
    "bg": { "value": "#ffffff", "use": "Primary background. White." },
    "bgMuted": { "value": "#f8f8f8", "use": "Soft frame outside the app. Almost-white." },
    "surfaceOverlay": { "value": "rgba(0, 0, 0, 0.03)", "use": "The 3% whisper. Hover, focus, active all share it." },
    "surfaceStrong": { "value": "rgba(0, 0, 0, 0.06)", "use": "Row hover, button rest. A step deeper." },
    "border": { "value": "rgba(0, 0, 0, 0.1)", "use": "Hairline dividers. Section breaks." },
    "borderStrong": { "value": "rgba(0, 0, 0, 0.2)", "use": "Focus rings, deeper rules." },
    "text": { "value": "#000000", "use": "Primary text. Pure black. Default." },
    "textMuted": { "value": "rgba(0, 0, 0, 0.5)", "use": "Metadata only: bylines, captions, hairlines." },
    "textSubtle": { "value": "rgba(0, 0, 0, 0.3)", "use": "Tertiary. Placeholders, softest labels." }
  },
  "colorForbidden": [
    "Brand colors",
    "Status colors (red/green/yellow as semantic)",
    "Any accent or secondary palette",
    "Gradients",
    "Custom alphas outside the nine tokens"
  ],
  "radius": {
    "sm": "12px",
    "md": "16px",
    "lg": "24px",
    "full": "9999px"
  },
  "space": {
    "base": "4px",
    "scale": {
      "1": "4px",
      "2": "8px",
      "3": "12px",
      "4": "16px",
      "5": "20px",
      "6": "24px",
      "7": "28px",
      "8": "32px",
      "10": "40px",
      "12": "48px",
      "15": "60px",
      "20": "80px"
    },
    "rule": "Every value is a multiple of 4. Off-grid spacing fails the linter."
  },
  "type": {
    "family": "PP Neue Montreal, system-ui, -apple-system, 'Helvetica Neue', sans-serif",
    "weights": {
      "regular": 500,
      "medium": 500,
      "bold": 700,
      "note": "Book (400) is loaded but forbidden by default — reads too thin on screen. Regular sits on Medium 500."
    },
    "scale": {
      "hero":     { "fontSize": "66px", "lineHeight": "66px", "use": "Document's own title, once per page." },
      "display":  { "fontSize": "38px", "lineHeight": "38px", "use": "Section headings." },
      "body":     { "fontSize": "22px", "lineHeight": "32px", "use": "Long-form reading text." },
      "title":    { "fontSize": "22px", "lineHeight": "28px", "use": "Card headings." },
      "subtitle": { "fontSize": "18px", "lineHeight": "24px", "use": "Nav headers, spec keys." },
      "caption":  { "fontSize": "16px", "lineHeight": "24px", "use": "UI labels, body inside cards." },
      "micro":    { "fontSize": "14px", "lineHeight": "20px", "use": "Captions, citations, metadata." }
    },
    "tracking": {
      "tight": "-0.01em",
      "tighter": "-0.03em"
    },
    "rules": [
      "One font, three weights, seven sizes.",
      "No italics outside of quotes.",
      "One distinction step per pair: bold vs regular, or big vs small, or black vs muted. Never all three.",
      "Sentence case in every heading. No Title Case. No ALL CAPS.",
      "Em-dashes forbidden in headlines, rare in body."
    ]
  },
  "motion": {
    "easing": {
      "out":    "cubic-bezier(0.2, 0, 0, 1)",
      "inOut":  "cubic-bezier(0.4, 0, 0.2, 1)",
      "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)",
      "swing":  "cubic-bezier(0.19, 1, 0.22, 1)"
    },
    "duration": {
      "fast": "120ms",
      "base": "200ms",
      "slow": "320ms",
      "long": "760ms"
    },
    "rules": [
      "Swing (easeOutExpo) is reserved for elegant long reveals. Too dramatic for hover/focus.",
      "prefers-reduced-motion collapses all durations to 0.01ms. Never override."
    ]
  },
  "layout": {
    "sidebarWidth": "260px",
    "inspectorWidth": "420px",
    "columnPadX": "clamp(1.25rem, 1.4vw, 1.5rem)",
    "docPadLeft": "clamp(2rem, 4.2vw, 3.75rem)",
    "docPadRight": "clamp(3rem, 8.3vw, 7.5rem)"
  }
}
